{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "clock/lobster-event",
  "title": "Clock Lobster Event",
  "description": "Event emitted by Clock via polarclaw-project-sdk to SOTAgent lobster event bus.",
  "type": "object",
  "required": ["ts", "type", "source_project", "severity", "payload", "dedup_key"],
  "properties": {
    "ts": { "type": "string", "format": "date-time" },
    "type": {
      "type": "string",
      "enum": ["bug", "contract_red", "scheduled_health_scan"],
      "description": "Clock only emits bug and health-related events"
    },
    "source_project": { "type": "string", "const": "clock" },
    "target_project": { "type": "string" },
    "severity": { "type": "string", "enum": ["info", "warn", "error", "critical"] },
    "payload": { "type": "object" },
    "dedup_key": { "type": "string" }
  },
  "additionalProperties": false
}
